# L4 01-08
Host hcgl??
    HostName %h
    User tony
    IdentityFile ~/.ssh/id_rsa
    LocalForward 8888 gcga01:58888
    #ProxyCommand ssh -CW %h:%p hgc
    ProxyJump hgc_vscode
