# Managed by chezmoi
# Keep this file safe to commit.

[user]
    name = {{ .name | quote }}
    email = {{ .email | quote }}

[init]
    defaultBranch = main

[pull]
    rebase = false

[push]
    autoSetupRemote = true

[core]
    editor = nvim
    excludesfile = ~/.config/git/ignore

{{ if eq .chezmoi.os "darwin" }}
[credential]
    helper = osxkeychain
{{ else if eq .chezmoi.os "windows" }}
[credential]
    helper = manager
{{ else if eq .chezmoi.os "linux" }}
[credential]
    helper = store
{{ end }}

# =============================================================================
# Directory-based identity switching
# =============================================================================
#
# Repositories under these directories can use different Git identities.
#
# Important:
# - The trailing slash is intentional.
# - includeIf paths are matched against repository paths.
# - Included files should define [user] name/email.
#
# Example:
#   ~/src/personal/foo/.git  -> ~/.gitconfig
#   ~/src/work/bar/.git      -> ~/.local/share/dotfiles-office/git/gitconfig-office
#
# [includeIf "gitdir:~/src/personal/"]
#    path = ~/.gitconfig
# [includeIf "gitdir:~/src/office/"]
#    path = ~/.local/share/dotfiles-office/git/gitconfig-office
