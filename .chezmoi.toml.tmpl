{{- $name := promptStringOnce . "name" "Your full name" -}}
{{- $personalEmail := promptStringOnce . "personal_email" "Personal Git email address" -}}
{{- $machineType := promptStringOnce . "machine_type" "Machine type: personal or office" -}}

[data]
name = {{ $name | quote }}
personal_email = {{ $personalEmail | quote }}
machine_type = {{ $machineType | quote }}

# Package installation is intentionally disabled by default.
install_packages = false
