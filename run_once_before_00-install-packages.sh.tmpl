#!/bin/sh

set -eu

{{ if .install_packages }}

echo "Installing packages..."

{{ if eq .chezmoi.os "darwin" }}

if command -v brew >/dev/null 2>&1; then
  brew install git zsh neovim starship
else
  echo "Homebrew is not installed. Skipping package installation."
fi

{{ else if eq .chezmoi.os "linux" }}

if command -v apt-get >/dev/null 2>&1; then
  sudo apt-get update
  sudo apt-get install -y git zsh neovim curl
else
  echo "apt-get is not available. Skipping package installation."
fi

{{ else }}

echo "Unsupported OS for package installation: {{ .chezmoi.os }}"

{{ end }}

{{ else }}

echo "install_packages=false. Skipping package installation."

{{ end }}
